<Window x:Class="The_organizers_of_the_BOO__quests.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:The_organizers_of_the_BOO__quests.View"
        mc:Ignorable="d"
        Title="БУ! Квесты Главное окно" MinHeight="900" MinWidth="1600" 
        Width="1920" Height="1080"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        ResizeMode="NoResize" Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <!-- Левая панель навигации -->
            <ColumnDefinition Width="*"/>
            <!-- Основной контент -->
        </Grid.ColumnDefinitions>

        <!-- Левая панель (навигация) -->
        <Border Grid.Column="0" Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="0,20,20,0" Margin="0,20,0,20"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Логотип -->
                    <RowDefinition Height="*"/>
                    <!-- Кнопки навигации -->
                    <RowDefinition Height="Auto"/>
                    <!-- Аккаунт и выход -->
                </Grid.RowDefinitions>

                <!-- Логотип компании (уменьшенный) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,30">
                    <TextBlock Text="БУ!" FontSize="36" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="квесты" FontSize="20" Foreground="{StaticResource LightGrayBrush}" VerticalAlignment="Bottom" Margin="5,0,0,5"/>
                </StackPanel>

                <!-- Навигационные кнопки -->
                <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="20,0,20,0">
                    <Button x:Name="HomeButton" Content="🏠 Главная" Style="{StaticResource NavButtonStyle}" Tag="Home"  Margin="0,5"/>
                    <Button x:Name="QuestsButton" Content="📊 Квесты и трафик" Style="{StaticResource NavButtonStyle}" Tag="Quests"  Margin="0,5"/>
                    <Button x:Name="RitualsButton" Content="📅 Ритуалы (Брони)" Style="{StaticResource NavButtonStyle}" Tag="Rituals"  Margin="0,5"/>
                    <Button x:Name="VictimsButton" Content="👥 Жертвы (Клиенты)" Style="{StaticResource NavButtonStyle}" Tag="Victims"  Margin="0,5"/>
                </StackPanel>

                <!-- Нижняя часть: аккаунт и выход -->
                <StackPanel Grid.Row="2" Margin="20,20,20,20">
                    <Border Background="{StaticResource InputBackgroundBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="UserNickname" Text="Иван Васильевич" FontSize="18" Foreground="{StaticResource ForegroundBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="LogoutButton" Content="🚪 Выход" Style="{StaticResource SecondaryButton}"  Height="45" Cursor=""/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область контента -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="{StaticResource PanelBackgroundBrush}"
                    CornerRadius="20" Margin="20"
                    Effect="{StaticResource CardShadow}">
                <ContentControl x:Name="MainContentArea" Margin="30">
                    <!-- Здесь будет отображаться выбранная страница (пока просто текст) -->
                    <TextBlock x:Name="ContentTextBlock" Text="Добро пожаловать в главное меню!" 
                               FontSize="24" Foreground="{StaticResource LightGrayBrush}" 
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ContentControl>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>
